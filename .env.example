# LLM provider: mock (default, no network) or openai
LLM_PROVIDER=mock

# Required when LLM_PROVIDER=openai
OPENAI_API_KEY=

# OpenAI model for structured extraction (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# SQLite database URL (default: sqlite:///deliverylint.db)
DATABASE_URL=sqlite:///deliverylint.db
